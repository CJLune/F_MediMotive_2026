      "permanent": true
    },
    {
      "source": "/supplier-quality-complaint-management.html",
      "destination": "/services/supplier-quality-complaint-management",
      "permanent": true
    },
    {
      "source": "/ramp-up-process-stability.html",
      "destination": "/services/ramp-up-process-stability",
      "permanent": true
    },
    {
      "source": "/early-phase-risk-design-for-quality.html",
      "destination": "/services/early-phase-risk-control-design-for-quality",
      "permanent": true
    },
    {
      "source": "/qms-audit-regulatory-support.html",
      "destination": "/services/qms-audit-regulatory-support",
      "permanent": true
    },
    {
      "source": "/knowledge-gap-transition-security.html",
      "destination": "/services/knowledge-gap-transition-security",
      "permanent": true
    },
    {
      "source": "/rapid-response-troubleshooting",
      "destination": "/services/rapid-response-troubleshooting",
      "permanent": true
    },
    {
      "source": "/supplier-quality-complaint-management",
      "destination": "/services/supplier-quality-complaint-management",
      "permanent": true
    },
    {
      "source": "/ramp-up-process-stability",
      "destination": "/services/ramp-up-process-stability",
      "permanent": true
    },
    {
      "source": "/early-phase-risk-design-for-quality",
      "destination": "/services/early-phase-risk-control-design-for-quality",
      "permanent": true
    },
    {
      "source": "/services/early-phase-risk-design-for-quality",
      "destination": "/services/early-phase-risk-control-design-for-quality",
      "permanent": true
    },
    {
      "source": "/qms-audit-regulatory-support",
      "destination": "/services/qms-audit-regulatory-support",
      "permanent": true
    },
    {
      "source": "/knowledge-gap-transition-security",
      "destination": "/services/knowledge-gap-transition-security",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/google-sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/medimotive-favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|google-sitemap\\.xml).*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; media-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/assets/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/services",
      "destination": "/services.html"
    },
    {
      "source": "/case-studies",
